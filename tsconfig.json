{
  "compilerOptions": {
    "isolatedModules": true,
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "rootDir": "./",
    "sourceMap": true,
    "paths": {
      "@models/*": [
        "./@cds-models/*/index.ts"
      ],
      "@/*": [
        "./srv/*"
      ],
    }
  },
  "include": [
    "srv"
  ],
  "exclude": [
    "node_modules"
  ]
}
